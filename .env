# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=webhook
POSTGRES_PASSWORD=webhook
POSTGRES_DB=webhook

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ── TPBank certs (đường dẫn tương đối từ thư mục tpb-backup/) ────────────────
TPBANK_PUBLIC_KEY_FILE=certs/bank_public.pem
TPBANK_UAT_PUBLIC_KEY_FILE=certs/bank_public_uat.pem
