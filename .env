# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=webhook
POSTGRES_PASSWORD=webhook
POSTGRES_DB=webhook

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ── TPBank certs (đường dẫn tương đối từ thư mục tpb-backup/) ────────────────
TPBANK_PUBLIC_KEY_FILE=certs/bank_public.pem
TPBANK_UAT_PUBLIC_KEY_FILE=certs/bank_public_uat.pem

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Tắt toàn bộ rate limit:       RATE_LIMIT_ENABLED=false
# Tắt riêng cho TPBank:         TPBANK_RATE_LIMIT_ENABLED=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW=60
# TPBANK_RATE_LIMIT_ENABLED=true  # uncomment + set false to disable for tpbank only
