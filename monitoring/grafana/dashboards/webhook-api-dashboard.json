{
  "id": null,
  "title": "Webhook API Monitoring",
  "tags": [
    "webhook",
    "api",
    "monitoring"
  ],
  "style": "dark",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(webhook_requests_total[5m])",
          "legendFormat": "{{method}} {{endpoint}} {{status}}"
        }
      ],
      "yAxes": [
        {
          "label": "Requests/second"
        }
      ],
      "xAxis": {
        "mode": "time"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Request Duration",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(webhook_request_duration_seconds_bucket[5m]))",
          "legendFormat": "95th percentile"
        },
        {
          "expr": "histogram_quantile(0.50, rate(webhook_request_duration_seconds_bucket[5m]))",
          "legendFormat": "50th percentile"
        }
      ],
      "yAxes": [
        {
          "label": "Seconds"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },
    {
      "id": 3,
      "title": "Signature Verification",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(signature_verification_total{status=\"success\"}[5m]))",
          "legendFormat": "✅ Success/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(signature_verification_total{status=\"invalid\"}[5m]))",
          "legendFormat": "❌ Invalid/s",
          "refId": "B"
        },
        {
          "expr": "sum(rate(signature_verification_total{status=\"missing\"}[5m]))",
          "legendFormat": "⚠️ Missing/s",
          "refId": "C"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area" },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 4,
      "title": "Rate Limit",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(rate_limit_total{status=\"allowed\"}[5m]))",
          "legendFormat": "✅ Allowed/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(rate_limit_total{status=\"exceeded\"}[5m]))",
          "legendFormat": "🚫 Blocked/s",
          "refId": "B"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area" },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 8
      }
    },
    {
      "id": 5,
      "title": "Error Rate",
      "type": "singlestat",
      "targets": [
        {
          "expr": "sum(rate(webhook_requests_total{status=~\"4.*|5.*\"}[5m])) / sum(rate(webhook_requests_total[5m]))",
          "legendFormat": "Error Rate"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 8
      }
    },
    {
      "id": 6,
      "title": "Active Connections",
      "type": "singlestat",
      "targets": [
        {
          "expr": "up{job=\"webhook-api\"}",
          "legendFormat": "Service Status"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 8
      }
    },
    {
      "id": 8,
      "title": "Saved JSON Files",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "webhook_saved_json_files_total{env=\"prod\"}",
          "legendFormat": "Production",
          "refId": "A"
        },
        {
          "expr": "webhook_saved_json_files_total{env=\"uat\"}",
          "legendFormat": "UAT",
          "refId": "B"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 12
      }
    },
    {
      "id": 7,
      "title": "Recent Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{job=\"webhook-api\"}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 16
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s"
}